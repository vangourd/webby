FROM docker.io/debian:trixie-slim

RUN apt-get update && apt-get install -y \
    ca-certificates \
    libssl3t64 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY webby ./
COPY site ./target/site
COPY migrations ./migrations
COPY Cargo.toml ./

# SQLite bundled into binary; /data is the PVC mount point
RUN mkdir -p /data logs

ENV LEPTOS_SITE_ROOT=/app/target/site
ENV LEPTOS_SITE_ADDR=0.0.0.0:8080
ENV DATABASE_URL=sqlite:///data/webby.db
ENV RUST_LOG=info

EXPOSE 8080
CMD ["./webby"]
