# Copy to /etc/webby-runner.env and edit for your host.
# systemd will expand these into the ExecStart of webby-runner.service.

# URL of the Webby server (http/https auto-rewritten to ws/wss).
WEBBY_SERVER_URL=http://webby.example.com

# How this runner appears in the Agents list. Also its identity across
# reconnects — same name means same runner_id, watchers stay attached.
WEBBY_RUNNER_NAME=my-host

# Shell to spawn as the PTY session. Change to /bin/zsh, /bin/fish, etc.
WEBBY_SHELL=/bin/bash
